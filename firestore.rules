rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // User profiles — authenticated users can read any profile; only owner can write
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
      allow delete: if false;
    }

    // Couples — only the two members can access their couple doc and every subcollection
    match /couples/{coupleId} {

      function isMember() {
        return request.auth != null &&
          request.auth.uid in resource.data.members;
      }

      function isMemberOnCreate() {
        return request.auth != null &&
          request.auth.uid in request.resource.data.members;
      }

      // Members can read their couple; any authenticated user can read a
      // couple that still has an inviteCode set (needed for the redeem query).
      allow read:   if isMember() ||
        (request.auth != null && resource.data.get('inviteCode', null) != null);
      allow create: if isMemberOnCreate();
      allow update: if isMember() ||
        // The second person claiming the invite is not yet a member on read,
        // but must be authenticated and the couple must still have a code.
        (request.auth != null && resource.data.get('inviteCode', null) != null &&
         request.auth.uid in request.resource.data.members);
      allow delete: if false;

      // All couple data: messages, moods, signals, letters, journal, memories,
      // bucketList, roomObjects, calls (incl. nested ICE candidate docs),
      // cinema (incl. nested reactions). Recursive so nested subcollections
      // like calls/{id}/callerCandidates/{id} are covered too.
      match /{path=**} {
        allow read, write: if request.auth != null &&
          request.auth.uid in
          get(/databases/$(database)/documents/couples/$(coupleId)).data.members;
      }
    }

    // Shared app config (e.g. config/webrtc TURN credentials) — read-only.
    match /config/{doc} {
      allow read: if request.auth != null;
      allow write: if false;
    }
  }
}
